<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_account_move_create_templates_from_bills" model="ir.actions.server">
        <field name="name">Create Vendor Bill Templates</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    "name": "Create Templates",
    "type": "ir.actions.act_window",
    "res_model": "vendor.bill.template.batch.from.bills.wizard",
    "view_mode": "form",
    "target": "new",
    "context": {"active_ids": records.ids},
}
        </field>
    </record>

    <record id="view_move_form_inherit_vendor_bill_template" model="ir.ui.view">
        <field name="name">account.move.form.inherit.vendor.bill.template</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_open_template_from_bill_wizard"
                    string="Create Template"
                    type="object"
                    invisible="move_type != 'in_invoice' or state == 'cancel'"
                />
            </xpath>
            <xpath expr="//sheet//group" position="inside">
                <field name="employee_contract_id" invisible="move_type != 'in_invoice'"/>
                <field name="vendor_bill_template_id" readonly="1" invisible="move_type != 'in_invoice'"/>
            </xpath>
        </field>
    </record>
</odoo>
