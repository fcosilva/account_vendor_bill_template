<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vendor_bill_template_batch_from_bills_wizard_form" model="ir.ui.view">
        <field name="name">vendor.bill.template.batch.from.bills.wizard.form</field>
        <field name="model">vendor.bill.template.batch.from.bills.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Templates from Vendor Bills">
                <group>
                    <field name="name_prefix"/>
                    <field name="bill_date_day"/>
                    <field name="auto_generate"/>
                    <field name="prevent_duplicate_period"/>
                    <field name="use_reference_sequence"/>
                </group>
                <group>
                    <field name="bill_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_create_templates" string="Create Templates" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vendor_bill_template_batch_from_bills_wizard" model="ir.actions.act_window">
        <field name="name">Create Templates</field>
        <field name="res_model">vendor.bill.template.batch.from.bills.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
